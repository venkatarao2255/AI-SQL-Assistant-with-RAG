{
  "tables": [
    {
      "table_name": "employees",
      "columns": [
        { "name": "emp_id", "type": "INT", "description": "Unique employee ID" },
        { "name": "first_name", "type": "VARCHAR", "description": "Employee first name" },
        { "name": "last_name", "type": "VARCHAR", "description": "Employee last name" },
        { "name": "email", "type": "VARCHAR", "description": "Employee email address" },
        { "name": "phone", "type": "VARCHAR", "description": "Employee phone number" },
        { "name": "hire_date", "type": "DATE", "description": "Date of joining" },
        { "name": "job_id", "type": "INT", "description": "Job role ID" },
        { "name": "salary", "type": "DECIMAL", "description": "Employee salary" },
        { "name": "manager_id", "type": "INT", "description": "Manager's employee ID" },
        { "name": "department_id", "type": "INT", "description": "Department ID" }
      ]
    },
    {
