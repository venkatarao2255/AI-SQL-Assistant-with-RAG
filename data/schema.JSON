        { "name": "min_salary", "type": "DECIMAL", "description": "Minimum salary for the job" },
        { "name": "max_salary", "type": "DECIMAL", "description": "Maximum salary for the job" }
      ]
    },
    {
      "table_name": "locations",
      "columns": [
