        { "name": "review_date", "type": "DATE", "description": "Performance review date" },
        { "name": "rating", "type": "INT", "description": "Performance rating (1-5)" }
      ]
    },
    {
      "table_name": "leaves",
      "columns": [
        { "name": "emp_id", "type": "INT", "description": "Employee ID" },
